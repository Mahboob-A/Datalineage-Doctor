APP_ENV=development
LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000

DATABASE_URL=postgresql+psycopg://dld:dld@db:5432/datalineage_doctor
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

LLM_API_KEY=replace-me
LLM_BASE_URL=https://api.cerebras.ai/v1
LLM_MODEL=llama3.1-8b
LLM_TIMEOUT_SECONDS=90
LLM_MAX_ITERATIONS=4
LLM_CLIENT_MAX_RETRIES=0
LLM_RATE_LIMIT_RETRIES=1
LLM_RATE_LIMIT_BACKOFF_SECONDS=12

OM_BASE_URL=http://openmetadata_server:8585/api/v1
# --- Auth strategy (choose one) ---
# Option A (Recommended): Non-expiring bot token — create once, never rotates.
# See knowledge/OM_jwt_token_generation.md for bot creation steps.
# Leave empty to fall back to Option B.
OM_JWT_TOKEN=
# Option B (Fallback): Admin credentials — client logs in automatically at
# runtime and refreshes on 401. No container restarts needed.
OM_ADMIN_EMAIL=admin@open-metadata.org
OM_ADMIN_PASSWORD=YWRtaW4=
OM_MAX_LINEAGE_DEPTH=3

SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
